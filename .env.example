# Database
# SQLite 本地数据库文件路径
DATABASE_URL="file:./dev.db"

# Admin Authentication
# 管理员密码（用于登录管理后台）
# 生成方法：openssl rand -base64 32
ADMIN_SECRET="your-admin-secret-here"

# Optional: Rate Limiting
# 登录失败次数限制（默认 5 次）
# LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Optional: Rate Limit Window (ms)
# 登录限制时间窗口（默认 60 秒 = 60000ms）
# LOGIN_RATE_LIMIT_WINDOW_MS=60000

# TOS (S3-Compatible Object Storage)
# 火山引擎 TOS Endpoint，例如: https://tos-cn-beijing.volces.com
TOS_ENDPOINT=""
TOS_REGION=""
TOS_BUCKET=""
TOS_ACCESS_KEY=""
TOS_SECRET_KEY=""

# Unified Object Storage Adapter
# 存储供应商: volc_s3 | tencent_cos
STORAGE_PROVIDER="volc_s3"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
# 仅用于拼接 CDN 公网 URL（可选）
STORAGE_CDN_DOMAIN=""

# Volc OBS/TOS (S3-compatible)
VOLC_ACCESS_KEY=""
VOLC_SECRET_KEY=""

# Tencent COS
TENCENT_SECRET_ID=""
TENCENT_SECRET_KEY=""
TENCENT_COS_APPID=""

# Static Files Base URL (for /uploads route forwarding)
# 本地 /public/uploads 不存在文件时，会 307 到该地址
# 例如: https://static.example.com
STATIC_BASE_URL=""
# 允许跳转的静态域名白名单（逗号分隔）
# 例如: static.example.com,cdn.example.com
STATIC_BASE_ALLOWED_HOSTS=""
